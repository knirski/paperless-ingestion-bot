{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"useTabs": true,
	"tabWidth": 2,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"ignorePatterns": [
		"dist/**",
		"node_modules/**",
		"coverage/**",
		"CHANGELOG.md",
		".github/PULL_REQUEST_TEMPLATE.md",
		"docs/adr/**"
	]
}
