{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.mjs",
			"!!**/dist",
			"!!**/node_modules",
			"!!**/coverage"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConsole": "error",
				"noExplicitAny": "error",
				"noVar": "error"
			},
			"style": {
				"noParameterAssign": "error",
				"noNonNullAssertion": "error",
				"useConst": "error",
				"useTemplate": "error",
				"useImportType": "error"
			},
			"complexity": {
				"noForEach": "error",
				"useOptionalChain": "error",
				"useFlatMap": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"useHookAtTopLevel": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["scripts/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		}
	],
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
