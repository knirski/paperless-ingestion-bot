{
	"name": "paperless-ingestion-bot",
	"version": "0.2.1",
	"description": "Signal and Gmail document ingestion for Paperless-ngx",
	"keywords": [
		"document-ingestion",
		"gmail",
		"imap",
		"paperless",
		"paperless-ngx",
		"signal"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/knirski/paperless-ingestion-bot.git"
	},
	"type": "module",
	"bin": {
		"paperless-ingestion-bot": "./dist/cli.js"
	},
	"files": [
		"dist",
		"config.example.json"
	],
	"scripts": {
		"start": "bun run src/cli.ts",
		"build": "bun run scripts/build.ts",
		"test": "bun test --coverage",
		"test:unit": "bun test",
		"test:integration": "bun test test/integration",
		"test:integration:live": "bun test test/integration/*.live.integration.test.ts",
		"test:watch": "bun test --watch",
		"check": "bash scripts/check-nix-hash.sh && bun run check:nix && bun run check:code && bun run check:docs && bun run lint:workflows && bun run lint:scripts",
		"check:ci": "bash scripts/run-check-ci.sh",
		"check:code": "bun run build && bun audit --audit-level=high && bun run lint && bun run knip && bun run typecheck && bun run test",
		"check:with-links": "bun run check && bun run check:just-links",
		"check:nix": "scripts/nix-run-if-missing.sh statix check . && scripts/nix-run-if-missing.sh deadnix --exclude bun.nix .",
		"check:docs": "bun x rumdl check . && scripts/nix-run-if-missing.sh typos",
		"check:just-links": "scripts/nix-run-if-missing.sh lychee --timeout 30 --max-retries 20 --retry-wait-time 5 --no-progress --accept 200,429 .",
		"lint": "biome check .",
		"lint:fix": "biome check . --write --unsafe",
		"lint:scripts": "find scripts -name '*.sh' -print0 | xargs -0 -r scripts/nix-run-if-missing.sh shellcheck && scripts/nix-run-if-missing.sh shfmt -d scripts",
		"format:scripts": "scripts/nix-run-if-missing.sh shfmt -w scripts",
		"lint:workflows": "scripts/nix-run-if-missing.sh actionlint",
		"format": "biome format --write .",
		"knip": "knip",
		"typecheck": "tsgo --noEmit",
		"prepublishOnly": "bun run build",
		"pack:dry": "bun run build && bun pm pack --dry-run"
	},
	"dependencies": {
		"@effect/platform-bun": "4.0.0-beta.36",
		"@napi-rs/keyring": "1.2.0",
		"effect": "4.0.0-beta.35",
		"file-type": "^21.3.1",
		"imapflow": "^1.2.12",
		"mime": "^4.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@commitlint/cli": "^20.4.4",
		"@commitlint/config-conventional": "^20.4.4",
		"@typescript/native-preview": "^7.0.0-dev",
		"bun-types": "^1.3.10",
		"fast-check": "^4.6.0",
		"knip": "^5.86.0",
		"lefthook": "^2.1.4",
		"lint-staged": "^16.3.2",
		"testcontainers": "^11.13.0",
		"typescript": "^5.7.0"
	},
	"lint-staged": {
		"*.{ts,tsx,json}": [
			"bun x biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		"*.md": [
			"bun x rumdl check --fix",
			"scripts/nix-run-if-missing.sh typos -w"
		],
		"*.sh": [
			"scripts/nix-run-if-missing.sh shfmt -w",
			"scripts/nix-run-if-missing.sh shellcheck"
		],
		".github/workflows/*.yml": [
			"scripts/nix-run-if-missing.sh actionlint"
		],
		"*.nix": [
			"scripts/nix-run-if-missing.sh statix fix"
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"packageManager": "bun@1.3.10"
}
