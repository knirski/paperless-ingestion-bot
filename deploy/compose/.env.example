# Paperless-ngx environment. Copy to .env before use. Compose loads .env for variable substitution.
# Required: set PAPERLESS_SECRET_KEY (long random string).
#
# See https://docs.paperless-ngx.com/configuration/ for all options.

# Required for full-stack compose
PAPERLESS_SECRET_KEY=change-me-to-a-long-random-string

# Required for ingestion-bot (API upload). Obtain via: POST /api/token/ (username+password),
# `python manage.py drf_create_token admin` (in webserver container), or Paperless UI.
#PAPERLESS_INGESTION_PAPERLESS_TOKEN=your-paperless-api-token

# Optional: UID/GID for Paperless consume dir (match your host user); unrelated to this project
#USERMAP_UID=1000
#USERMAP_GID=1000

# Optional: timezone, OCR language, etc.
#PAPERLESS_TIME_ZONE=America/Los_Angeles
#PAPERLESS_OCR_LANGUAGE=eng
